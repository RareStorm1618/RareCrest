# Sample Caddy reverse proxy for a RareCrest VPS cutover.
# Copy to Caddyfile, replace the placeholders, and let Caddy manage TLS automatically
# (or point `tls` at your own cert/key). See docs/VPS-CUTOVER.md for the full walkthrough.
#
# RareCrest's own services (apps/api, apps/web) never terminate TLS themselves — this
# proxy is the TLS boundary. governance-engine/intelligence/scoring stay loopback-only
# and are never exposed through this proxy.

your-domain.example {
	# TLS: Caddy issues/renews certs automatically for a public domain. For an internal-only
	# CA or manual certs, replace the block above with:
	#   tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.pem

	encode gzip

	# API — apps/api, default port 3000. Bind API_HOST to 0.0.0.0 only behind this proxy,
	# with AUTH_TRUST_MODE=strict + CORS_ALLOWED_ORIGINS + INTERNAL_SERVICE_TOKEN set.
	handle /api/* {
		reverse_proxy api:3000
	}
	handle /health {
		reverse_proxy api:3000
	}
	handle /metrics {
		reverse_proxy api:3000
	}

	# Web app — apps/web, default port 5173 (or your static build's serve port).
	handle {
		reverse_proxy web:5173
	}

	log {
		output file /var/log/caddy/rarecrest-access.log
	}
}

# Never proxy these directly to the internet — they stay on the private/loopback network:
#   governance-engine (default 127.0.0.1:3001, override via GOVERNANCE_HOST)
#   intelligence       (default 127.0.0.1:3002, override via INTELLIGENCE_HOST)
#   scoring            (default 127.0.0.1:3003, override via SCORING_HOST)
