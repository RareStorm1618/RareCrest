    "seed": "node dist/seed.js"
  },
  "dependencies": {
    "@rarecrest/contracts": "workspace:*",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
