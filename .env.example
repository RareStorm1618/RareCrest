# RareCrest Environment Variables
# Copy to .env and adjust for your environment

# PostgreSQL (scoped credentials per service)
DATABASE_URL=postgresql://rarecrest_api:rarecrest_api_dev@localhost:5432/rarecrest
GOVERNANCE_DATABASE_URL=postgresql://rarecrest_governance:rarecrest_governance_dev@localhost:5432/rarecrest
INTELLIGENCE_DATABASE_URL=postgresql://rarecrest_intelligence:rarecrest_intelligence_dev@localhost:5432/rarecrest

# Object Store (MinIO)
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY=rarecrest_minio
OBJECT_STORE_SECRET_KEY=rarecrest_minio_dev
OBJECT_STORE_BUCKET=rarecrest-exports

# Vector Store (Qdrant)
VECTOR_STORE_URL=http://localhost:6333
VECTOR_STORE_COLLECTION=framework-canon

# API Server
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production-use-managed-secrets

# Governance Engine (internal RPC)
GOVERNANCE_ENGINE_URL=http://localhost:3001

# Intelligence Services (internal RPC)
INTELLIGENCE_SERVICES_URL=http://localhost:3002

# Node environment
NODE_ENV=development
