# RareCrest Environment Variables
# Copy to .env and adjust for your environment

# PostgreSQL (scoped credentials per service)
DATABASE_URL=postgresql://rarecrest_api:rarecrest_api_dev@localhost:55432/rarecrest
GOVERNANCE_DATABASE_URL=postgresql://rarecrest_governance:rarecrest_governance_dev@localhost:55432/rarecrest
INTELLIGENCE_DATABASE_URL=postgresql://rarecrest_intelligence:rarecrest_intelligence_dev@localhost:55432/rarecrest

# Object Store (MinIO)
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY=rarecrest_minio
OBJECT_STORE_SECRET_KEY=rarecrest_minio_dev
OBJECT_STORE_BUCKET=rarecrest-exports

# Vector Store (Qdrant)
VECTOR_STORE_URL=http://localhost:6333
VECTOR_STORE_COLLECTION=framework-canon

# API Server
API_PORT=3000
API_HOST=0.0.0.0

# Auth — use AUTH_TRUST_MODE=strict + OIDC in any shared/prod environment
AUTH_TRUST_MODE=dev
JWT_SECRET=change-me-in-production-use-managed-secrets
# OIDC_ISSUER=https://your-idp.example/
# OIDC_AUDIENCE=rarecrest-api
# OIDC_JWKS_URL=https://your-idp.example/.well-known/jwks.json

# Internal service auth (set the same value on API, governance, intelligence)
# INTERNAL_SERVICE_TOKEN=replace-from-secrets-manager
# INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/internal_service_token

# PHI KMS — prefer KEK or remote KMS (Docker/K8s: use *_FILE)
# PHI_KMS_KEK=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# PHI_KMS_KEK_FILE=/run/secrets/phi_kms_kek
# PHI_KMS_ENDPOINT=https://kms-broker.internal
# PHI_KMS_TOKEN=replace-from-secrets-manager
# PHI_KMS_KEY_ID=local-kek-v1
# Legacy dev-only fallback (insufficient alone when AUTH_TRUST_MODE=strict):
# PHI_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Governance Engine (internal RPC)
GOVERNANCE_ENGINE_URL=http://localhost:3001

# Intelligence Services (internal RPC)
INTELLIGENCE_SERVICES_URL=http://localhost:3002

# Node environment
NODE_ENV=development

# Web / mobile Bearer (preferred over header shim)
# VITE_API_BEARER_TOKEN=
# EXPO_PUBLIC_API_BEARER_TOKEN=